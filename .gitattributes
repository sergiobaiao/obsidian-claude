# Ensure shell scripts and Python always use LF line endings
*.sh        text eol=lf
*.py        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.gitignore text eol=lf

# Windows .cmd shims keep CRLF so cmd.exe is happy
*.cmd       text eol=crlf

# PowerShell scripts keep CRLF
*.ps1       text eol=crlf
